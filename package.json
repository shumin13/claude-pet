{
  "name": "claude-pet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "hook": "node hooks/claude-pet-notify.js",
    "build:desktop": "mkdir -p .build/module-cache && CLANG_MODULE_CACHE_PATH=.build/module-cache swiftc macos/RobotPetOverlay.swift -framework Cocoa -framework WebKit -o .build/robot-pet-overlay",
    "desktop": "scripts/run-desktop.sh",
    "test": "node tests/pet-integration.test.js",
    "package:zip": "mkdir -p .build && zip -qr .build/claude-pet-source.zip .gitignore SPEC.md README.md package.json server.js lib hooks scripts public docs tests macos"
  }
}
